{
  "name": "clintestbench",
  "private": true,
  "workspaces": [
    "apps/*",
    "services/*",
    "workers/*",
    "packages/*"
  ],
  "scripts": {
    "test": "conda run -n ctb pytest -q --maxfail=1 --disable-warnings",
    "build:frontend": "npm -w apps/frontend run build",
    "dev:frontend": "npm -w apps/frontend run dev",
    "ci:api": "conda run -n ctb pytest -q --maxfail=1 --disable-warnings --cov=services/api",
    "ci:workers": "conda run -n ctb pytest -q --maxfail=1 --disable-warnings --cov=workers/runner"
  },
  "devDependencies": {}
}
